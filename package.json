{
  "name": "ruyi-big-screen",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 10001",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 10001",
    "check": "vue-tsc -b",
    "lint": "npm run lint:eslint && npm run lint:style",
    "lint:eslint": "eslint .",
    "lint:style": "stylelint \"src/**/*.{css,vue}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "screenshot": "node scripts/capture-dashboard.mjs",
    "screenshot:dashboard": "node scripts/capture-dashboard.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "axios": "^1.11.0",
    "echarts": "^5.6.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.0.14",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/runtime-dom": "^3.5.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "msw": "^2.10.4",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.22.0",
    "stylelint-config-standard": "^39.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^3.0.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
